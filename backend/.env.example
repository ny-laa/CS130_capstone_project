#g backend env vars. copy to .env and fill in. .env is gitignored.
#empty values are fine for local dev unless you're touching that subsystem.

#runtime
APP_ENV=development         #dev | staging | prod
LOG_LEVEL=INFO

#db -- supabase tx pooler uri (port 6543)
#prefix with `postgresql+psycopg2://` and url-encode any special chars in pwd
DATABASE_URL=

SUPABASE_URL=               
SUPABASE_ANON_KEY=          
SUPABASE_SERVICE_ROLE_KEY=  #SECRET, bypasses RLS

#twilio 
TWILIO_ACCOUNT_SID=         
TWILIO_AUTH_TOKEN=         
TWILIO_PHONE_NUMBER=        


#llm
ANTHROPIC_API_KEY=          
OPENAI_API_KEY=             

#stt
DEEPGRAM_API_KEY=

#google api -- calendar + gmail
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

#celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
